---
import '../styles/global.css';
import LanguagePicker from '~/components/LanguagePicker.astro';
import { t, LANGUAGES } from '~/lib/i18n';

interface Props {
  title?: string;
  description?: string;
  /** Pages that render a Leaflet map should set this to load the map's stylesheet. */
  leaflet?: boolean;
}

const {
  title = 'FairPlan — Brampton APS Modernization',
  description = 'AI-native administrative penalty modernization and personalized payment experience for the City of Brampton.',
  leaflet = false,
} = Astro.props;

const user = Astro.locals.user;
const lang = Astro.locals.lang;
const htmlLang = lang;
const dir = LANGUAGES[lang].dir;
const initials = user?.name
  .split(' ')
  .map((s) => s[0])
  .filter(Boolean)
  .slice(0, 2)
  .join('')
  .toUpperCase() ?? '';

const path = Astro.url.pathname;
const isCurrent = (href: string) => (href === '/' ? path === '/' : path === href || path.startsWith(href + '/'));
---

<!doctype html>
<html lang={htmlLang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&display=swap"
    />
    {leaflet && <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />}
    <title>{title}</title>
  </head>
  <body class="min-h-screen gradient-trust">
    <a href="#main" class="skip-link">{t(lang, 'a11y.skip_to_content')}</a>

    <header class="border-b border-line/60 bg-surface/80 backdrop-blur supports-[backdrop-filter]:bg-surface/60">
      <div class="mx-auto flex max-w-[1400px] items-center justify-between px-6 py-4 lg:px-10">
        <a href="/" class="flex items-center gap-2.5">
          <span class="grid h-9 w-9 place-items-center rounded-lg bg-ink text-fair">
            <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" aria-hidden="true">
              <path d="M5 7h6v2.5H7.5V12H11v2.5H5z" fill="currentColor" />
              <circle cx="17" cy="12" r="4" stroke="currentColor" stroke-width="1.5" />
              <path
                d="m15.2 12 1.2 1.2 2.6-2.6"
                stroke="#FAFAF7"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </span>
          <span class="flex flex-col leading-tight">
            <span class="font-display text-lg font-semibold tracking-tight">FairPlan</span>
            <span class="text-[10px] uppercase tracking-[0.18em] text-ink-subtle">for Brampton APS</span>
          </span>
        </a>
        <nav class="hidden items-center gap-7 text-sm font-medium text-ink-soft md:flex" aria-label="Primary">
          <a href="/" aria-current={isCurrent('/') ? 'page' : undefined} class="hover:text-ink transition-colors">
            {t(lang, 'nav.portal')}
          </a>
          {user?.role === 'resident' && (
            <a
              href="/my-notices"
              aria-current={isCurrent('/my-notices') ? 'page' : undefined}
              class="text-fair-dark hover:text-ink transition-colors"
            >
              {t(lang, 'nav.my_notices')}
            </a>
          )}
          <a
            href="/dashboard"
            aria-current={isCurrent('/dashboard') ? 'page' : undefined}
            class="hover:text-ink transition-colors"
          >
            {t(lang, 'nav.dashboard')}
          </a>
          <a
            href="/bylaws"
            aria-current={isCurrent('/bylaws') ? 'page' : undefined}
            class="hover:text-ink transition-colors"
          >
            Bylaws
          </a>
          {(user?.role === 'officer' || user?.role === 'manager') && (
            <>
              <a
                href="/officer"
                aria-current={isCurrent('/officer') ? 'page' : undefined}
                class="text-fair-dark hover:text-ink transition-colors"
              >
                Screening queue
              </a>
              <a
                href="/hearings"
                aria-current={isCurrent('/hearings') ? 'page' : undefined}
                class="text-fair-dark hover:text-ink transition-colors"
              >
                Hearings
              </a>
            </>
          )}
          {user?.role === 'manager' && (
            <a
              href="/manager"
              aria-current={isCurrent('/manager') ? 'page' : undefined}
              class="text-fair-dark hover:text-ink transition-colors"
            >
              Manager
            </a>
          )}
          <a
            href="/about"
            aria-current={isCurrent('/about') ? 'page' : undefined}
            class="hover:text-ink transition-colors"
          >
            {t(lang, 'nav.about')}
          </a>
        </nav>
        <div class="flex items-center gap-3">
          <LanguagePicker current={lang} />
          <a href="/" class="hidden btn-ghost text-sm border border-line md:inline-flex">
            {t(lang, 'nav.check_ticket')}
          </a>
          {
            user ? (
              <>
                <div class="hidden text-right md:block">
                  <p class="text-sm font-medium leading-tight text-ink">{user.name}</p>
                  <p class="text-[10px] uppercase tracking-[0.16em] text-ink-subtle">{user.role}</p>
                </div>
                <span
                  class="grid h-9 w-9 place-items-center rounded-full bg-fair/15 text-xs font-semibold text-fair-dark"
                  aria-hidden="true"
                >
                  {initials}
                </span>
                <form method="POST" action="/api/auth/logout" class="contents">
                  <button type="submit" class="btn-ghost text-sm border border-line">
                    {t(lang, 'nav.sign_out')}
                  </button>
                </form>
              </>
            ) : (
              <>
                <a href="/login" class="hidden text-sm font-medium text-ink-soft hover:text-ink md:inline">
                  {t(lang, 'nav.sign_in')}
                </a>
                <a href="/signup" class="btn-primary text-sm">
                  {t(lang, 'nav.create_account')}
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path
                      d="M5 12h14m-5-5 5 5-5 5"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </a>
              </>
            )
          }
        </div>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="mt-24 border-t border-line/60 bg-ink text-white/85">
      <div class="mx-auto grid max-w-[1400px] gap-10 px-6 py-14 md:grid-cols-4 lg:px-10">
        <div class="md:col-span-2">
          <p class="font-display text-2xl font-semibold tracking-tight text-white">FairPlan</p>
          <p class="mt-3 max-w-prose text-sm text-white/70">
            A proof of concept for the City of Brampton's Administrative Penalty System Modernization &amp; Personalized
            Payment Experience program. Not affiliated with the City. Built on Cloudflare.
          </p>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-white/50">Built with</p>
          <ul class="mt-3 space-y-1.5 text-sm">
            <li>Cloudflare Workers</li>
            <li>Workers AI · AI Gateway</li>
            <li>D1 · R2 · KV</li>
            <li>Browser Rendering</li>
          </ul>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-white/50">Public data</p>
          <ul class="mt-3 space-y-1.5 text-sm">
            <li>Brampton GeoHub</li>
            <li>Statistics Canada 2021</li>
            <li>Bank of Canada Valet</li>
          </ul>
        </div>
      </div>
      <div class="border-t border-white/10">
        <div class="mx-auto flex max-w-[1400px] flex-col items-start gap-2 px-6 py-5 text-xs text-white/60 md:flex-row md:items-center md:justify-between lg:px-10">
          <span>© 2026 FairPlan POC. Brampton, Ontario.</span>
          <span>v0.1 · 1-day sprint build</span>
        </div>
      </div>
    </footer>
  </body>
</html>
