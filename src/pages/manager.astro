---
import Base from '~/layouts/Base.astro';
import { requireRole } from '~/lib/auth';
import { decisionMix, managerKpis, offenceLoad, wardLoad } from '~/lib/db';
import { getBramptonProfile } from '~/lib/data/statcan';

const guard = requireRole(Astro.locals.user, ['manager']);
if (!guard.ok) return Astro.redirect(guard.redirect);

const env = Astro.locals.runtime.env;
const [kpis, mix, byWard, byOffence, profile] = await Promise.all([
  managerKpis(env.DB),
  decisionMix(env.DB),
  wardLoad(env.DB),
  offenceLoad(env.DB),
  getBramptonProfile(),
]);

const DECISION_META: Record<string, { label: string; tone: string }> = {
  cancelled: { label: 'Cancelled', tone: 'bg-fair text-ink' },
  reduced: { label: 'Reduced', tone: 'bg-warn text-ink' },
  upheld: { label: 'Upheld', tone: 'bg-ink text-white' },
  hearing_required: { label: 'Sent to hearing', tone: 'bg-indigo-500 text-white' },
};

const totalDecided = mix.reduce((a, r) => a + r.n, 0);
const wardMax = Math.max(1, ...byWard.map((w) => w.openCases));

const kpiBlocks = [
  { label: 'Open reviews', value: kpis.openReviews.toString(), sub: 'In screening queue', accent: false },
  { label: 'Decided this week', value: kpis.decidedThisWeek.toString(), sub: 'Last 7 days', accent: false },
  {
    label: 'Cancellation rate',
    value: `${Math.round(kpis.cancellationRate * 100)}%`,
    sub: 'Of all decided reviews',
    accent: false,
  },
  {
    label: 'Hearing referrals',
    value: `${Math.round(kpis.hearingRate * 100)}%`,
    sub: 'Of all decided reviews',
    accent: false,
  },
  { label: 'Active payment plans', value: kpis.plansActive.toString(), sub: 'FairPlan instalments', accent: false },
  {
    label: 'Total open balance',
    value: `$${kpis.totalDueDollars.toLocaleString('en-CA', { maximumFractionDigits: 0 })}`,
    sub: 'Unpaid notices',
    accent: true,
  },
];
---

<Base title="Manager analytics · FairPlan">
  <section class="border-b border-line/60">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10 py-12 md:py-16">
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-fair-dark">Manager console</p>
      <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight md:text-5xl text-balance">
        Operational view, hands-on context.
      </h1>
      <p class="mt-3 max-w-prose text-ink-soft">
        Trends across the screening queue, decision mix, geographic load, and equity overlays — drawn from D1 and
        Statistics Canada at request time.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-[1400px] px-6 lg:px-10 pt-10">
    <div class="grid gap-px overflow-hidden rounded-2xl border border-line bg-line md:grid-cols-3 lg:grid-cols-6">
      {
        kpiBlocks.map((k) => (
          <div class={`bg-surface-raised p-6 ${k.accent ? 'ring-1 ring-fair/30' : ''}`}>
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-ink-subtle">{k.label}</p>
            <p class={`mt-2 font-display text-2xl font-semibold tracking-tight ${k.accent ? 'text-fair-dark' : 'text-ink'}`}>
              {k.value}
            </p>
            {k.sub && <p class="mt-1 text-xs text-ink-subtle">{k.sub}</p>}
          </div>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-[1400px] px-6 lg:px-10 py-12">
    <div class="grid gap-8 lg:grid-cols-[1fr_1.2fr]">
      <article class="card overflow-hidden">
        <div class="border-b border-line bg-surface-sunken px-6 py-4">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-ink-subtle">Decision mix</p>
          <p class="mt-1 font-display text-lg font-semibold">
            {totalDecided} {totalDecided === 1 ? 'decision' : 'decisions'} to date
          </p>
        </div>
        <div class="px-6 py-6">
          {totalDecided === 0 ? (
            <p class="text-sm text-ink-soft">No decisions recorded yet.</p>
          ) : (
            <div class="space-y-4">
              <div class="flex h-3 overflow-hidden rounded-full bg-surface-sunken">
                {mix.map((m) => {
                  const meta = DECISION_META[m.decision] ?? DECISION_META.upheld;
                  const pct = (m.n / totalDecided) * 100;
                  return <span class={`block h-full ${meta.tone}`} style={`width:${pct}%`} title={`${meta.label}: ${m.n}`} />;
                })}
              </div>
              <ul class="space-y-2 text-sm">
                {mix.map((m) => {
                  const meta = DECISION_META[m.decision] ?? DECISION_META.upheld;
                  const pct = ((m.n / totalDecided) * 100).toFixed(0);
                  return (
                    <li class="flex items-center justify-between">
                      <span class="flex items-center gap-2.5">
                        <span class={`h-2.5 w-2.5 rounded-full ${meta.tone}`} aria-hidden="true" />
                        <span class="font-medium text-ink">{meta.label}</span>
                      </span>
                      <span class="font-mono text-ink-subtle">
                        {m.n} · {pct}%
                      </span>
                    </li>
                  );
                })}
              </ul>
            </div>
          )}
        </div>
      </article>

      <article class="card overflow-hidden">
        <div class="border-b border-line bg-surface-sunken px-6 py-4">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-ink-subtle">Ward load</p>
          <p class="mt-1 font-display text-lg font-semibold">Open notices by ward</p>
        </div>
        <div class="px-6 py-6">
          <ul class="space-y-3">
            {byWard.map((w) => {
              const pct = (w.openCases / wardMax) * 100;
              return (
                <li>
                  <div class="flex items-center justify-between text-sm">
                    <span class="font-medium text-ink">Ward {w.ward}</span>
                    <span class="font-mono text-ink-subtle">
                      {w.openCases} open · ${w.totalDueDollars.toLocaleString('en-CA', { maximumFractionDigits: 0 })}
                    </span>
                  </div>
                  <div class="mt-1.5 h-1.5 overflow-hidden rounded-full bg-surface-sunken">
                    <div class="h-full rounded-full bg-fair" style={`width:${pct}%`} />
                  </div>
                </li>
              );
            })}
          </ul>
        </div>
      </article>
    </div>
  </section>

  <section class="mx-auto max-w-[1400px] px-6 lg:px-10 pb-12">
    <article class="card overflow-hidden">
      <div class="border-b border-line bg-surface-sunken px-6 py-4 md:flex md:items-end md:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-ink-subtle">Offence breakdown</p>
          <p class="mt-1 font-display text-lg font-semibold">Volume and revenue exposure</p>
        </div>
        <p class="mt-2 text-xs text-ink-subtle md:mt-0">January 2026 penalty schedule in effect</p>
      </div>
      <table class="w-full divide-y divide-line text-sm">
        <thead class="bg-surface-sunken text-left">
          <tr>
            <th class="px-5 py-3 text-xs font-semibold uppercase tracking-[0.14em] text-ink-subtle">Offence</th>
            <th class="px-5 py-3 text-xs font-semibold uppercase tracking-[0.14em] text-ink-subtle">Notices</th>
            <th class="px-5 py-3 text-xs font-semibold uppercase tracking-[0.14em] text-ink-subtle">Total exposure</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-line bg-surface-raised">
          {
            byOffence.map((o) => (
              <tr>
                <td class="px-5 py-3 text-ink">{o.offence_label}</td>
                <td class="px-5 py-3 font-mono text-ink-soft">{o.n}</td>
                <td class="px-5 py-3 font-mono text-ink-soft">
                  ${(o.total_cents / 100).toLocaleString('en-CA')}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </article>
  </section>

  <section class="mx-auto max-w-[1400px] px-6 lg:px-10 pb-24">
    <article class="card overflow-hidden">
      <div class="border-b border-line bg-surface-sunken px-6 py-4">
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-ink-subtle">Equity context</p>
        <p class="mt-1 font-display text-lg font-semibold">Brampton at a glance</p>
        <p class="mt-1 text-xs text-ink-subtle">
          Used by the FairPlan agent to calibrate hardship bands · Statistics Canada Census 2021, CSD 3521010
        </p>
      </div>
      <div class="grid gap-px bg-line md:grid-cols-3">
        <div class="bg-surface-raised p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-ink-subtle">Population</p>
          <p class="mt-2 font-display text-2xl font-semibold">{profile.totalPopulation.toLocaleString('en-CA')}</p>
        </div>
        <div class="bg-surface-raised p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-ink-subtle">Median household income</p>
          <p class="mt-2 font-display text-2xl font-semibold">${profile.medianHouseholdIncomeCAD.toLocaleString('en-CA')}</p>
        </div>
        <div class="bg-surface-raised p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-ink-subtle">Below LIM-AT</p>
          <p class="mt-2 font-display text-2xl font-semibold">{profile.lowIncomePctLIM}%</p>
        </div>
      </div>
    </article>
  </section>
</Base>
