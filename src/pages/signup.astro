---
import Base from '~/layouts/Base.astro';
import TicketLookup from '~/components/TicketLookup.tsx';
import { buildCookie, createUser, signSession } from '~/lib/auth';

const env = Astro.locals.runtime.env;

if (Astro.locals.user) {
  return Astro.redirect('/');
}

let formError: string | null = null;
let emailValue = '';
let nameValue = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  emailValue = String(form.get('email') ?? '').trim();
  nameValue = String(form.get('name') ?? '').trim();
  const password = String(form.get('password') ?? '');

  if (!emailValue || !nameValue || !password) {
    formError = 'Please fill in name, email, and password.';
  } else if (password.length < 8) {
    formError = 'Password must be at least 8 characters.';
  } else {
    try {
      const user = await createUser(env.DB, { email: emailValue, name: nameValue, password });
      const token = await signSession(env, user);
      return new Response(null, {
        status: 303,
        headers: {
          location: '/',
          'set-cookie': buildCookie(token, env.ENV !== 'dev'),
        },
      });
    } catch (e) {
      formError = (e as Error).message;
    }
  }
}
---

<Base title="Create account · FairPlan">
  <section class="mx-auto max-w-[1200px] px-6 pt-14 pb-12 md:pt-20">
    <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="min-w-0">
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-fair-dark">Create an account</p>
        <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight md:text-5xl">
          A short signup, then you're in.
        </h1>
        <p class="mt-4 max-w-prose text-ink-soft">
          You'll get a Resident account by default. Brampton staff are provisioned by their manager.
        </p>

        <form method="POST" class="mt-10 space-y-5" novalidate>
          <div>
            <label for="email" class="block text-sm font-medium text-ink">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              required
              value={emailValue}
              class="input mt-2"
              placeholder="you@example.com"
            />
          </div>

          <div>
            <label for="name" class="block text-sm font-medium text-ink">Your name</label>
            <input
              id="name"
              name="name"
              type="text"
              autocomplete="name"
              required
              value={nameValue}
              class="input mt-2"
              placeholder="Priya Sandhu"
            />
          </div>

          <div>
            <label for="password" class="block text-sm font-medium text-ink">Choose a password</label>
            <p class="mt-1 text-xs text-ink-subtle">At least 8 characters.</p>
            <input
              id="password"
              name="password"
              type="password"
              autocomplete="new-password"
              required
              minlength="8"
              class="input mt-2"
              placeholder="••••••••"
            />
          </div>

          {
            formError && (
              <div class="rounded-xl border border-danger/30 bg-danger/5 p-4 text-sm text-danger" role="alert">
                {formError}
              </div>
            )
          }

          <div class="flex flex-wrap items-center justify-between gap-4 border-t border-line pt-6">
            <p class="text-sm text-ink-subtle">
              Already have one?{' '}
              <a href="/login" class="text-ink underline underline-offset-4">Sign in</a>
            </p>
            <button type="submit" class="btn-primary">Create account</button>
          </div>
        </form>
      </div>

      <aside class="min-w-0">
        <div class="card overflow-hidden">
          <div class="border-b border-line bg-surface-sunken px-6 py-5">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-fair-dark">What you get</p>
            <p class="mt-1 font-display text-lg font-semibold text-ink">A resident account</p>
          </div>
          <ul class="divide-y divide-line text-sm">
            <li class="px-6 py-4">
              <p class="font-medium text-ink">Look up any notice tied to you</p>
              <p class="mt-0.5 text-ink-subtle">Plate and address are matched automatically once you're signed in.</p>
            </li>
            <li class="px-6 py-4">
              <p class="font-medium text-ink">Personalized payment plans</p>
              <p class="mt-0.5 text-ink-subtle">Hardship-aware, 0% APR, calibrated to your household.</p>
            </li>
            <li class="px-6 py-4">
              <p class="font-medium text-ink">Notice history &amp; reminders</p>
              <p class="mt-0.5 text-ink-subtle">Every interaction logged for FOI/audit. Reminders in your language.</p>
            </li>
          </ul>
          <div class="border-t border-line bg-surface-sunken px-6 py-4">
            <p class="text-xs text-ink-subtle">
              Want to test as a Screening Officer or Manager? Sign in with the demo accounts on the{' '}
              <a href="/login" class="text-ink underline underline-offset-4">login page</a>.
            </p>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="mx-auto max-w-[1200px] px-6 pb-24">
    <div class="card p-6 md:p-8">
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-fair-dark">No account needed</p>
          <p class="mt-1 font-display text-lg font-semibold text-ink">
            Just want to check a notice? Enter it here.
          </p>
        </div>
        <div class="md:w-[26rem]">
          <TicketLookup client:load variant="inline" />
        </div>
      </div>
    </div>
  </section>
</Base>
