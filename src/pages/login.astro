---
import Base from '~/layouts/Base.astro';
import TicketLookup from '~/components/TicketLookup.tsx';
import {
  buildCookie,
  findUserByEmail,
  seedDemoUsersIfNeeded,
  signSession,
  verifyPassword,
  type SessionUser,
} from '~/lib/auth';
import { logAudit } from '~/lib/db';

const env = Astro.locals.runtime.env;

if (Astro.locals.user) {
  return Astro.redirect('/');
}

let formError: string | null = null;
let emailValue = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  emailValue = String(form.get('email') ?? '').trim();
  const password = String(form.get('password') ?? '');

  if (!emailValue || !password) {
    formError = 'Email and password are required.';
  } else {
    await seedDemoUsersIfNeeded(env.DB);
    const row = await findUserByEmail(env.DB, emailValue);
    if (!row || !(await verifyPassword(password, row.password_hash))) {
      formError = 'No account matches that email and password.';
    } else {
      const user: SessionUser = { id: row.id, email: row.email, name: row.name, role: row.role };
      const token = await signSession(env, user);
      await logAudit(env.DB, { actor: `user:${row.id}`, action: 'login' });
      return new Response(null, {
        status: 303,
        headers: {
          location: '/',
          'set-cookie': buildCookie(token, env.ENV !== 'dev'),
        },
      });
    }
  }
}

const demos = [
  { label: 'Resident', email: 'resident@brampton.demo' },
  { label: 'Screening Officer', email: 'officer@brampton.demo' },
  { label: 'Manager', email: 'manager@brampton.demo' },
];
const DEMO_PASSWORD = 'fairplan2026';
---

<Base title="Sign in · FairPlan">
  <section class="mx-auto max-w-[1200px] px-6 pt-14 pb-12 md:pt-20">
    <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="min-w-0">
        <p class="font-mono text-xs uppercase tracking-[0.18em] text-fair-dark">Sign in</p>
        <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight md:text-5xl">
          Welcome back to FairPlan.
        </h1>
        <p class="mt-4 max-w-prose text-ink-soft">
          Residents and Brampton staff use the same portal — your role determines what you can see.
        </p>

        <form method="POST" class="mt-10 space-y-5" novalidate>
          <div>
            <label for="email" class="block text-sm font-medium text-ink">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              required
              value={emailValue}
              class="input mt-2"
              placeholder="you@example.com"
            />
          </div>

          <div>
            <label for="password" class="block text-sm font-medium text-ink">Password</label>
            <input
              id="password"
              name="password"
              type="password"
              autocomplete="current-password"
              required
              class="input mt-2"
              placeholder="••••••••"
            />
          </div>

          {
            formError && (
              <div class="rounded-xl border border-danger/30 bg-danger/5 p-4 text-sm text-danger" role="alert">
                {formError}
              </div>
            )
          }

          <div class="flex flex-wrap items-center justify-between gap-4 border-t border-line pt-6">
            <p class="text-sm text-ink-subtle">
              New here?{' '}
              <a href="/signup" class="text-ink underline underline-offset-4">Create an account</a>
            </p>
            <button type="submit" class="btn-primary">Sign in</button>
          </div>
        </form>
      </div>

      <aside class="min-w-0">
        <div class="card overflow-hidden">
          <div class="border-b border-line bg-surface-sunken px-6 py-5">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-fair-dark">For reviewers</p>
            <p class="mt-1 font-display text-lg font-semibold text-ink">Sample credentials</p>
            <p class="mt-1 text-xs text-ink-subtle">
              Click a role to autofill. Password is <span class="font-mono text-ink">{DEMO_PASSWORD}</span>.
            </p>
          </div>
          <ul class="divide-y divide-line">
            {
              demos.map((d) => (
                <li>
                  <button
                    type="button"
                    data-demo-email={d.email}
                    class="demo-fill flex w-full items-center justify-between gap-4 px-6 py-4 text-left transition hover:bg-surface-sunken"
                  >
                    <div class="min-w-0">
                      <p class="text-sm font-medium text-ink">{d.label}</p>
                      <p class="mt-0.5 truncate font-mono text-xs text-ink-subtle">{d.email}</p>
                    </div>
                    <span class="pill bg-fair/10 text-xs text-fair-dark">Use</span>
                  </button>
                </li>
              ))
            }
          </ul>
          <div class="border-t border-line bg-surface-sunken px-6 py-4">
            <p class="text-xs text-ink-subtle">
              Demo accounts are created on first sign-in. Passwords are PBKDF2-SHA256 hashed; sessions are
              HMAC-signed cookies — see <span class="font-mono">src/lib/auth.ts</span>.
            </p>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="mx-auto max-w-[1200px] px-6 pb-24">
    <div class="card p-6 md:p-8">
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-fair-dark">No sign-in needed</p>
          <p class="mt-1 font-display text-lg font-semibold text-ink">
            Just want to check a notice? Enter it here.
          </p>
        </div>
        <div class="md:w-[26rem]">
          <TicketLookup client:load variant="inline" />
        </div>
      </div>
    </div>
  </section>
</Base>

<script is:inline define:vars={{ DEMO_PASSWORD }}>
  document.querySelectorAll('.demo-fill').forEach((btn) => {
    btn.addEventListener('click', () => {
      const email = btn.getAttribute('data-demo-email') ?? '';
      const emailInput = document.getElementById('email');
      const passwordInput = document.getElementById('password');
      if (emailInput) emailInput.value = email;
      if (passwordInput) passwordInput.value = DEMO_PASSWORD;
      emailInput?.focus();
    });
  });
</script>
