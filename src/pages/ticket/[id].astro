---
import Base from '~/layouts/Base.astro';
import TicketExperience from '~/components/TicketExperience.tsx';
import { getTicket, listRemindersForTicket } from '~/lib/db';
import { findPenalty } from '~/lib/data/penalties';
import { scheduleNoticeReminders } from '~/lib/reminders';

const env = Astro.locals.runtime.env;
const id = Astro.params.id?.toUpperCase() ?? '';
const ticket = id ? await getTicket(env.DB, id) : null;
const penalty = ticket ? findPenalty(ticket.offence_code) ?? null : null;

if (!ticket) {
  return Astro.redirect('/not-found?id=' + encodeURIComponent(id));
}

await scheduleNoticeReminders(env.DB, {
  ticket,
  userId: Astro.locals.user?.id ?? ticket.user_id ?? null,
});
const reminders = await listRemindersForTicket(env.DB, ticket.id);
---

<Base title={`Notice ${ticket.id} · FairPlan`}>
  <section class="mx-auto max-w-[1400px] px-6 lg:px-10 pt-14 pb-24 md:pt-20">
    <nav class="mb-8 text-sm">
      <a href="/" class="text-ink-subtle hover:text-ink">← Back to resident portal</a>
    </nav>
    <TicketExperience client:load ticket={ticket} penalty={penalty} reminders={reminders} language={Astro.locals.lang} />
  </section>
</Base>
