---
import Base from '~/layouts/Base.astro';
import TicketLookup from '~/components/TicketLookup.tsx';

const id = new URL(Astro.request.url).searchParams.get('id') ?? '';
---

<Base title="Notice not found · FairPlan">
  <section class="mx-auto max-w-2xl px-6 py-24 text-center">
    <p class="font-mono text-xs uppercase tracking-[0.18em] text-fair-dark">404 · Not found</p>
    <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight md:text-5xl">
      We couldn't find that notice.
    </h1>
    <p class="mt-4 text-ink-soft">
      {id ? <>The notice <span class="font-mono">{id}</span> isn't in our records. Double-check the number on the back of your ticket.</> : 'Try entering the notice number again.'}
    </p>
    <div class="mx-auto mt-10 max-w-md text-left">
      <TicketLookup client:load variant="inline" />
    </div>
  </section>
</Base>
