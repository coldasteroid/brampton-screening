---
import Base from '~/layouts/Base.astro';
import BylawSearch from '~/components/BylawSearch.tsx';
import { BYLAW_CORPUS } from '~/lib/rag/bylaws';

const byCategory = BYLAW_CORPUS.reduce<Record<string, typeof BYLAW_CORPUS>>((acc, c) => {
  (acc[c.category] ??= []).push(c);
  return acc;
}, {});

const CATEGORY_LABEL: Record<string, string> = {
  parking: 'Parking & Traffic',
  property: 'Property Standards',
  rental: 'Rental Licensing',
  safety: 'Safety',
  procedure: 'AMPS Procedure (Ontario)',
};
---

<Base title="Bylaws · FairPlan">
  <section class="border-b border-line/60">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10 py-12 md:py-16">
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-fair-dark">Knowledge base</p>
      <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight md:text-5xl text-balance">
        The bylaws our agent reads.
      </h1>
      <p class="mt-4 max-w-prose text-ink-soft">
        Every screening recommendation is grounded in the City's published by-laws and Ontario's Administrative
        Monetary Penalty System framework. This page shows the same corpus the agent retrieves from — so reviewers
        can see exactly what's being cited.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-[1400px] px-6 lg:px-10 py-12">
    <p class="font-mono text-xs uppercase tracking-[0.18em] text-fair-dark">Try a query</p>
    <h2 class="mt-2 font-display text-2xl font-semibold tracking-tight">Search the corpus</h2>
    <p class="mt-2 max-w-prose text-sm text-ink-soft">
      Free-text retrieval against the indexed bylaws. Production replaces this with Workers AI <span class="font-mono">bge-m3</span>
      embeddings + Cloudflare Vectorize — same skill signature, one import swap.
    </p>
    <div class="mt-6">
      <BylawSearch client:load />
    </div>
  </section>

  <section class="mx-auto max-w-[1400px] px-6 lg:px-10 pb-24">
    <p class="font-mono text-xs uppercase tracking-[0.18em] text-fair-dark">Indexed corpus</p>
    <h2 class="mt-2 font-display text-2xl font-semibold tracking-tight">{BYLAW_CORPUS.length} sections, {Object.keys(byCategory).length} categories</h2>

    <div class="mt-8 space-y-10">
      {
        Object.entries(byCategory).map(([cat, chunks]) => (
          <section>
            <h3 class="font-display text-lg font-semibold text-ink">{CATEGORY_LABEL[cat] ?? cat}</h3>
            <ul class="mt-4 grid gap-3 md:grid-cols-2">
              {chunks.map((c) => (
                <li class="card p-5">
                  <p class="font-mono text-xs text-ink-subtle">{c.bylaw} · {c.section}</p>
                  <p class="mt-1 font-medium text-ink">{c.title}</p>
                  <p class="mt-2 text-sm leading-relaxed text-ink-soft">{c.body}</p>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </section>
</Base>
