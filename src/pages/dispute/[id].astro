---
import Base from '~/layouts/Base.astro';
import DisputeForm from '~/components/DisputeForm.tsx';
import { getTicket } from '~/lib/db';

const env = Astro.locals.runtime.env;
const id = Astro.params.id?.toString().toUpperCase() ?? '';
const ticket = id ? await getTicket(env.DB, id) : null;

if (!ticket) return Astro.redirect('/not-found?id=' + encodeURIComponent(id));
---

<Base title={`Screening Review · ${ticket.id} · FairPlan`}>
  <section class="mx-auto max-w-[1400px] px-6 lg:px-10 pt-12 pb-24 md:pt-16">
    <nav class="mb-8 text-sm">
      <a href={`/ticket/${ticket.id}`} class="text-ink-subtle hover:text-ink">← Back to notice {ticket.id}</a>
    </nav>
    <header class="mb-10 max-w-3xl">
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-fair-dark">Screening Review</p>
      <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight md:text-5xl text-balance">
        Ask the City to take another look.
      </h1>
      <p class="mt-4 text-ink-soft">
        Under Brampton's APS, you have 15 days from the date on the notice to request a Screening Review. There's no
        cost to file. A human Screening Officer always decides.
      </p>
    </header>
    <DisputeForm client:load ticket={ticket} />
  </section>
</Base>
