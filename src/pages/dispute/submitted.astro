---
import Base from '~/layouts/Base.astro';
import { getReview } from '~/lib/db';

const env = Astro.locals.runtime.env;
const id = new URL(Astro.request.url).searchParams.get('id') ?? '';
const review = id ? await getReview(env.DB, id) : null;
---

<Base title="Review submitted · FairPlan">
  <section class="mx-auto max-w-2xl px-6 py-24 text-center">
    <span class="mx-auto grid h-14 w-14 place-items-center rounded-full bg-fair/15 text-fair-dark">
      <svg viewBox="0 0 24 24" fill="none" class="h-7 w-7" aria-hidden="true">
        <path d="m5 12 5 5 9-11" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </span>
    <h1 class="mt-6 font-display text-4xl font-semibold tracking-tight">Screening Review submitted.</h1>
    <p class="mt-3 text-ink-soft">
      Your case is in the queue. The FairPlan agent will draft a pre-screening recommendation within minutes; a human
      Screening Officer reviews it next.
    </p>
    {review && (
      <p class="mt-6 font-mono text-xs text-ink-subtle">
        Review ID: {review.id} · Notice {review.ticket_id}
      </p>
    )}
    <div class="mt-10 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
      <a href="/" class="btn-primary text-sm">Back to portal</a>
      {review && (
        <a href={`/ticket/${review.ticket_id}`} class="btn-ghost text-sm border border-line">
          View notice
        </a>
      )}
    </div>
  </section>
</Base>
