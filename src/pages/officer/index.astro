---
import Base from '~/layouts/Base.astro';
import { requireRole } from '~/lib/auth';
import { listOpenReviews } from '~/lib/db';

const guard = requireRole(Astro.locals.user, ['officer', 'manager']);
if (!guard.ok) return Astro.redirect(guard.redirect);

const env = Astro.locals.runtime.env;
const reviews = await listOpenReviews(env.DB);

const stats = [
  { label: 'Open reviews', value: reviews.length, accent: false },
  { label: 'Awaiting first look', value: reviews.filter((r) => r.status === 'submitted').length, accent: false },
  { label: 'In progress', value: reviews.filter((r) => r.status === 'under_review').length, accent: false },
  { label: 'High priority', value: reviews.filter((r) => r.priority_score >= 0.8).length, accent: true },
];

const REASON_LABELS: Record<string, string> = {
  financial_hardship: 'Financial hardship',
  factual_dispute: 'Factual dispute',
  exceptional_circumstances: 'Exceptional circumstances',
};

function reasonsOf(json: string): string[] {
  try {
    return (JSON.parse(json) as string[]).map((r) => REASON_LABELS[r] ?? r);
  } catch {
    return [];
  }
}

function timeAgo(iso: string): string {
  const h = Math.floor((Date.now() - Date.parse(iso)) / 3_600_000);
  if (h < 1) return 'just now';
  if (h < 24) return `${h}h ago`;
  return `${Math.floor(h / 24)}d ago`;
}

function priorityTone(score: number): { dot: string; label: string } {
  if (score >= 0.85) return { dot: 'bg-danger', label: 'Critical' };
  if (score >= 0.6) return { dot: 'bg-warn', label: 'High' };
  return { dot: 'bg-fair', label: 'Standard' };
}
---

<Base title="Screening queue · FairPlan">
  <section class="border-b border-line/60">
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10 py-12 md:py-16">
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-fair-dark">Screening Officer console</p>
      <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight md:text-5xl text-balance">
        Your queue, prioritized.
      </h1>
      <p class="mt-3 max-w-prose text-ink-soft">
        Every case is pre-screened by the FairPlan agent with a non-binding recommendation, bylaw citation, and risk
        flags. You always have the final decision.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-[1400px] px-6 lg:px-10 pt-8">
    <div class="grid gap-px overflow-hidden rounded-2xl border border-line bg-line md:grid-cols-4">
      {
        stats.map((s) => (
          <div class={`bg-surface-raised p-6 ${s.accent ? 'ring-1 ring-fair/30' : ''}`}>
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-ink-subtle">{s.label}</p>
            <p class={`mt-2 font-display text-3xl font-semibold tracking-tight ${s.accent ? 'text-fair-dark' : 'text-ink'}`}>
              {s.value}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-[1400px] px-6 lg:px-10 py-12">
    {
      reviews.length === 0 ? (
        <div class="card p-12 text-center">
          <p class="font-display text-2xl font-semibold">Queue clear.</p>
          <p class="mt-2 text-ink-soft">New screening reviews will appear here as residents submit them.</p>
        </div>
      ) : (
        <ol class="space-y-3">
          {reviews.map((r) => {
            const tone = priorityTone(r.priority_score);
            return (
              <li>
                <a
                  href={`/officer/${r.id}`}
                  class="card flex flex-col gap-4 p-6 transition hover:shadow-md md:flex-row md:items-center"
                >
                  <div class="flex items-center gap-4 md:w-72 md:shrink-0">
                    <span class="flex flex-col items-center gap-1">
                      <span class={`h-2.5 w-2.5 rounded-full ${tone.dot}`} aria-hidden="true" />
                      <span class="text-[10px] uppercase tracking-[0.14em] text-ink-subtle">{tone.label}</span>
                    </span>
                    <div class="min-w-0">
                      <p class="font-mono text-xs text-ink-subtle">{r.ticket_id}</p>
                      <p class="mt-0.5 truncate font-medium text-ink">{r.offence_label}</p>
                    </div>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex flex-wrap items-center gap-2">
                      {reasonsOf(r.reasons).map((label) => (
                        <span class="pill bg-surface-sunken text-ink-soft">{label}</span>
                      ))}
                      {r.status === 'under_review' && (
                        <span class="pill bg-fair/10 text-fair-dark">AI draft ready</span>
                      )}
                    </div>
                    <p class="mt-2 max-w-prose text-sm text-ink-soft line-clamp-2">{r.narrative}</p>
                  </div>
                  <div class="flex items-center justify-between gap-4 md:flex-col md:items-end md:gap-1 md:shrink-0">
                    <p class="font-display text-lg font-semibold text-ink">
                      ${(r.amount_cents / 100).toLocaleString('en-CA')}
                    </p>
                    <p class="text-xs text-ink-subtle">Submitted {timeAgo(r.created_at)}</p>
                  </div>
                </a>
              </li>
            );
          })}
        </ol>
      )
    }
  </section>
</Base>
