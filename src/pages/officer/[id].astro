---
import Base from '~/layouts/Base.astro';
import OfficerCase from '~/components/OfficerCase.tsx';
import { requireRole } from '~/lib/auth';
import { getReview, getTicket, listEvidence } from '~/lib/db';
import type { OfficerRecommendation } from '~/lib/agents/skills';

const guard = requireRole(Astro.locals.user, ['officer', 'manager']);
if (!guard.ok) return Astro.redirect(guard.redirect);

const env = Astro.locals.runtime.env;
const id = Astro.params.id?.toString() ?? '';
const review = id ? await getReview(env.DB, id) : null;

if (!review) return Astro.redirect('/officer');

const [ticket, evidence] = await Promise.all([
  getTicket(env.DB, review.ticket_id),
  listEvidence(env.DB, review.id),
]);

const recommendation: OfficerRecommendation | null = review.ai_recommendation
  ? (JSON.parse(review.ai_recommendation) as OfficerRecommendation)
  : null;
---

<Base title={`Review ${review.id} · FairPlan`}>
  <section class="mx-auto max-w-[1400px] px-6 lg:px-10 pt-12 pb-24 md:pt-16">
    <nav class="mb-8 text-sm">
      <a href="/officer" class="text-ink-subtle hover:text-ink">← Back to queue</a>
    </nav>
    {ticket && <OfficerCase client:load review={review} initialRecommendation={recommendation} evidence={evidence} />}
  </section>
</Base>
