---
import Base from '~/layouts/Base.astro';
import PlanRecommender from '~/components/PlanRecommender.tsx';
import { getTicket } from '~/lib/db';

const env = Astro.locals.runtime.env;
const url = new URL(Astro.request.url);
const id = (url.searchParams.get('ticket') ?? '').toUpperCase();
const ticket = id ? await getTicket(env.DB, id) : null;

if (!ticket) {
  return Astro.redirect('/not-found?id=' + encodeURIComponent(id));
}
---

<Base title={`Personalized plan · ${ticket.id} · FairPlan`}>
  <section class="mx-auto max-w-[1400px] px-6 lg:px-10 pt-14 pb-24 md:pt-20">
    <nav class="mb-8 text-sm">
      <a href={`/ticket/${ticket.id}`} class="text-ink-subtle hover:text-ink">← Back to notice {ticket.id}</a>
    </nav>
    <PlanRecommender client:load ticket={ticket} language={Astro.locals.lang} />
  </section>
</Base>
