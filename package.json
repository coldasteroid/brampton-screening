{
  "name": "fairplan",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "FairPlan — AI-native APS Modernization & Personalized Payment Experience for the City of Brampton",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:worker": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare build && wrangler dev",
    "deploy": "opennextjs-cloudflare build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:apply:local": "node scripts/apply-migrations.mjs --local",
    "db:apply:remote": "node scripts/apply-migrations.mjs --remote"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.0.0",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.475.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250501.0",
    "@types/leaflet": "^1.9.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.28.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0",
    "wrangler": "^4.99.0"
  },
  "engines": {
    "node": ">=20"
  }
}
